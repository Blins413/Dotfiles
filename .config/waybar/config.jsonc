{
	"include": [
		"~/.config/waybar/modules.jsonc"
	],
	"layer": "top",
	"exclusive": true,
	"passthrough": false,
	"position": "top",
	"spacing": 3,
	"fixed-center": true,
	"ipc": true,
	"margin-top": 6,
	"margin-left": 8,
	"margin-right": 8,
	"reload_style_on_change": true,
	"modules-left": [
		"tray",
		"hyprland/window"
	],
	"modules-center": [
		"hyprland/workspaces#rw"
	],
	"modules-right": [
		"battery",
		"bluetooth",
		"pulseaudio",
		"clock",
		"custom/power"
	]
}
